{
  "name": "bucketdrive",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:unit": "turbo test:unit",
    "test:contracts": "turbo test:contracts",
    "test:e2e": "turbo test:e2e",
    "db:generate": "turbo db:generate",
    "db:migrate:dev": "tsx scripts/migrate.ts",
    "db:migrate:staging": "wrangler d1 migrations apply bucketdrive-db-staging --env staging",
    "db:migrate:prod": "wrangler d1 migrations apply bucketdrive-db --env production",
    "db:seed": "tsx scripts/seed.ts",
    "db:studio": "turbo db:studio",
    "db:reset": "rm -f apps/api/.db/local.sqlite && pnpm db:migrate:dev && pnpm db:seed",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "sql.js": "^1.14.1",
    "tsx": "^4.19.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.2",
    "uuid": "^10.0.0"
  }
}
