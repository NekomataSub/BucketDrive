{
  "name": "bucketdrive",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:unit": "turbo test:unit",
    "test:contracts": "turbo test:contracts",
    "test:e2e": "turbo test:e2e",
    "test:a11y": "playwright test apps/web/e2e/a11y.spec.ts",
    "db:generate": "turbo db:generate",
    "db:migrate:dev": "pnpm --filter @bucketdrive/api exec wrangler --config ../../wrangler.toml d1 migrations apply bucketdrive-db --local",
    "db:migrate:staging": "pnpm --filter @bucketdrive/api exec wrangler --config ../../wrangler.toml d1 migrations apply bucketdrive-db-staging --env staging",
    "db:migrate:prod": "pnpm --filter @bucketdrive/api exec wrangler --config ../../wrangler.toml d1 migrations apply bucketdrive-db --env production",
    "db:seed": "tsx scripts/seed.ts",
    "db:studio": "turbo db:studio",
    "db:reset": "rm -rf .wrangler/state/v3/d1 apps/api/.db/local.sqlite && pnpm db:migrate:dev && pnpm db:seed",
    "db:reset:empty": "rm -rf .wrangler/state/v3/d1 apps/api/.db/local.sqlite && pnpm db:migrate:dev",
    "env:check": "tsx scripts/env.ts check",
    "env:check:staging": "tsx scripts/env.ts check staging",
    "env:check:production": "tsx scripts/env.ts check production",
    "env:link": "tsx scripts/env.ts link",
    "env:prepare": "tsx scripts/env.ts prepare",
    "env:prepare:staging": "tsx scripts/env.ts prepare staging",
    "env:prepare:production": "tsx scripts/env.ts prepare production",
    "env:push": "tsx scripts/env.ts push",
    "env:push:staging": "tsx scripts/env.ts push staging",
    "env:push:production": "tsx scripts/env.ts push production",
    "env:push:prod": "tsx scripts/env.ts push production",
    "r2:verify": "pnpm --filter @bucketdrive/api exec tsx ../../scripts/verify-r2.ts",
    "r2:cors:dev": "tsx scripts/apply-r2-cors.ts",
    "staging:prepare": "tsx scripts/prepare-staging-config.ts",
    "staging:check": "tsx scripts/check-staging-config.ts",
    "perf:bundle": "pnpm build && tsx scripts/check-bundle-size.ts",
    "perf:lighthouse": "pnpm build && lhci autorun",
    "perf:benchmark": "PLAYWRIGHT_INCLUDE_BENCHMARKS=true playwright test apps/web/e2e/performance.benchmark.spec.ts",
    "perf:check": "pnpm perf:bundle && pnpm perf:lighthouse",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "sql.js": "^1.14.1",
    "tsx": "^4.22.4",
    "turbo": "^2.9.17",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "uuid": "^14.0.0"
  }
}
