{
  "rules": [
    {
      "allowed": {
        "origins": [
          "http://localhost:5173",
          "http://127.0.0.1:5173",
          "http://localhost:5174",
          "http://127.0.0.1:5174"
        ],
        "methods": [
          "GET",
          "PUT",
          "HEAD"
        ],
        "headers": [
          "Content-Type",
          "Range",
          "Authorization",
          "x-amz-*"
        ]
      },
      "exposeHeaders": [
        "ETag",
        "Content-Length",
        "Content-Range"
      ],
      "maxAgeSeconds": 86400
    }
  ]
}
