{
  "name": "@bucketdrive/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schemas/*": "./src/schemas/*",
    "./contracts/*": "./src/contracts/*",
    "./constants": "./src/constants.ts",
    "./db/*": "./src/db/*"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test:unit": "vitest run",
    "test:contracts": "vitest run --config vitest.config.ts src/__tests__/contracts",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@libsql/client": "^0.17.3",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
